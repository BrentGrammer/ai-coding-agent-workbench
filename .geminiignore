node_modules/
dist/
build/
.next/
coverage/
*.log
*.map

# Secrets and credentials. Used by both Gemini CLI and Antigravity. It blocks
# the native file reader (with Agent Gitignore Access off) but NOT terminal
# reads like `cat .env` — the agent's shell tool bypasses it, which Google has
# called intended behavior. Defense-in-depth only. The reliable control is not
# mounting the secret.
.env*
!.env.template
!.env.example
*.pem
*.key
*.p12
*.pfx
id_rsa
id_ed25519
.ssh/
.aws/
.gnupg/
.netrc
.git-credentials
**/credentials*
**/*secret*

# macOS
.DS_Store

# Git / VCS
.git/

# Python caches
__pycache__/
*.py[cod]
.mypy_cache/
.pytest_cache/
.ruff_cache/

# Coverage reports
.coverage
htmlcov/

# Virtualenv: do not include installed packages in Gemini context/tools
.venv/

# Local AI/tool state
.cline/
.codex/
opencode.json
.clineignore

# Serena MCP
# Keep .serena/project*.yml and .serena/memories/ visible.
.serena/cache/
# ignore this if you have secrets there and have sensitive config setup: .serena/project.local.yml