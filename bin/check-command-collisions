#!/usr/bin/env bash
set -euo pipefail

BIN_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd -P)"
IFS=':' read -r -a path_entries <<< "$PATH"
collision_found=0

for command_path in "$BIN_DIR"/*; do
  if [ ! -f "$command_path" ] || [ ! -x "$command_path" ]; then
    continue
  fi

  command_name="$(basename "$command_path")"

  for path_entry in "${path_entries[@]}"; do
    path_entry="${path_entry:-.}"
    candidate="$path_entry/$command_name"

    if [ ! -f "$candidate" ] || [ ! -x "$candidate" ]; then
      continue
    fi

    candidate_directory="$(cd "$(dirname "$candidate")" && pwd -P)"
    if [ "$candidate_directory" = "$BIN_DIR" ]; then
      continue
    fi

    printf '%s already exists at %s\n' "$command_name" "$candidate"
    collision_found=1
  done
done

if [ "$collision_found" -eq 0 ]; then
  echo "No command collisions found."
  exit 0
fi

echo "Command collisions found. Existing commands will take priority when the workbench bin directory is appended to PATH."
exit 1
