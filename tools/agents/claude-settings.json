{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "allowManagedPermissionRulesOnly": true,
  "permissions": {
    "defaultMode": "acceptEdits",
    "deny": [
      "Read(.env)",
      "Read(.env.local)",
      "Read(.env.development)",
      "Read(.env.production)",
      "Read(.env.staging)",
      "Read(.env.test)",
      "Read(.envrc)",
      "Read(.netrc)",
      "Read(.npmrc)",
      "Read(.pgpass)",
      "Read(.git-credentials)",
      "Read(~/.ssh)",
      "Read(~/.gnupg)",
      "Read(~/.aws/credentials)",
      "Read(~/.aws/config)",
      "Read(~/.kube/config)",
      "Read(~/.docker/config.json)",
      "Read(~/.config/gh/hosts.yml)",
      "Read(~/.codex/auth.json)",
      "Read(~/.gemini/oauth_creds.json)",
      "Read(~/.local/share/opencode/auth.json)",
      "Read(~/.claude/.credentials.json)",
      "Read(~/.claude/history.jsonl)"
    ]
  },
  "sandbox": {
    "enabled": true,
    "failIfUnavailable": true,
    "autoAllowBashIfSandboxed": true,
    "excludedCommands": ["git:*"],
    "filesystem": {
      "denyRead": [
        ".env",
        ".env.*",
        "**/.env",
        "**/.env.*",
        "**/.envrc",
        "**/.netrc",
        "**/.pgpass",
        "**/.git-credentials",
        "**/*.pem",
        "**/*.key",
        "~/.ssh/**",
        "~/.gnupg/**",
        "~/.aws/credentials",
        "~/.kube/config",
        "~/.docker/config.json",
        "~/.config/gh/hosts.yml",
        "~/.codex/auth.json",
        "~/.gemini/oauth_creds.json",
        "~/.local/share/opencode/auth.json",
        "~/.claude/.credentials.json",
        "~/.claude/history.jsonl",
        "~/.claude/projects/**"
      ],
      "allowRead": ["**/.env.template", "**/.env.example"]
    }
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "/usr/local/bin/deny-protected-file-reads",
            "args": [],
            "timeout": 10
          }
        ]
      }
    ]
  }
}
